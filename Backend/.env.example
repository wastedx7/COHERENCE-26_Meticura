# Backend Environment Variables

# Security & JWT
SECRET_KEY=your-secret-key-change-in-production-min-32-chars-long

# Super Admin Credentials (for initialization)
SUPER_ADMIN_EMAIL=admin@meticura.gov
SUPER_ADMIN_PASSWORD=Admin@123!meticura
SUPER_ADMIN_NAME=System Administrator

# Clerk Authentication (deprecated, kept for backwards compatibility)
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key_here
CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key_here

# API Configuration
API_V1_PREFIX=/api
PROJECT_NAME=Budget Watchdog API

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/budget_watchdog

# Redis
REDIS_URL=redis://localhost:6379/0

# CORS - Add your frontend URLs (JSON format for pydantic-settings)
ALLOWED_ORIGINS=["http://localhost:3000", "http://localhost:5173"]
