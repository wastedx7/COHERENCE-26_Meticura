# Budget Watchdog - Environment Configuration Template
# Copy this to .env and fill in actual values

# =====================================================
# Clerk Authentication
# =====================================================
CLERK_SECRET_KEY=your_clerk_secret_key_here
CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here
CLERK_JWT_VERIFICATION_KEY=your_clerk_jwt_verification_key_here

# =====================================================
# Database (PostgreSQL / Supabase)
# =====================================================
# For local PostgreSQL:
DATABASE_URL=postgresql://budget_user:budget_password@localhost:5432/budget_watchdog

# For Supabase (replace with your connection string):
# DATABASE_URL=postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres?schema=public

# =====================================================
# Redis Cache & Celery Broker
# =====================================================
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# =====================================================
# ML Models
# =====================================================
ML_MODEL_PATH=ml/artifacts/model.pkl
ML_SCALER_PATH=ml/artifacts/scaler.pkl

# =====================================================
# Celery Configuration
# =====================================================
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_TIMEZONE=Asia/Kolkata
CELERY_ENABLE_UTC=true

# =====================================================
# API Configuration
# =====================================================
API_V1_PREFIX=/api
PROJECT_NAME=Budget Watchdog API

# =====================================================
# CORS Configuration
# =====================================================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173

# =====================================================
# Logging Configuration
# =====================================================
LOG_LEVEL=INFO
LOG_FILE=logs/budget_watchdog.log

# =====================================================
# Frontend Configuration
# =====================================================
VITE_API_BASE_URL=http://localhost:8000/api
VITE_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here

# =====================================================
# Pipeline Scheduling
# =====================================================
PIPELINE_RUN_INTERVAL_HOURS=6
RETRAIN_DAY_OF_WEEK=6
RETRAIN_TIME=02:00

# =====================================================
# Feature Flags (for gradual rollout)
# =====================================================
FEATURE_ML_ANOMALIES=true
FEATURE_LAPSE_PREDICTION=true
FEATURE_REALLOCATION_SUGGESTIONS=true
FEATURE_ADVANCED_FILTERING=true
FEATURE_EXPORT_CSV=true
FEATURE_EXPORT_PDF=true
